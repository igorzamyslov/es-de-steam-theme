{
  // Theme docs are prose-heavy; relax the rules that fight readable Markdown.
  "default": true,
  "MD013": false,        // no hard line-length limit
  "MD033": false,        // allow inline HTML (badges, <kbd>, etc.)
  "MD041": false,        // first line need not be a top-level heading
  "MD036": false,        // allow bold callouts (e.g. **Recommended:**) that aren't headings
  "MD024": { "siblings_only": true } // duplicate headings ok under different parents
}
