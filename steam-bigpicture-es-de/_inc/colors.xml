<theme>
    <!-- Shared palette. Kept as global variables (not inside a colorScheme block) because the
         colorScheme axis is repurposed to pick the detail-panel media behaviour, not colours -
         every scheme shares this one dark palette. cAccent is the single brand accent (a bright
         Steam blue): the active nav underline and the focused system icon both use it, so it stays
         consistent and always legible regardless of platform. Per-system colour lives in the hero
         tint (${systemColor}), not the accent. Background/panel/green colours are baked into the
         SVG assets in assets/ui/. -->
    <variables>
        <cAccent>33a8ffff</cAccent>
        <cText>e8edf2ff</cText>
        <cText2>aab4c0ff</cText2>
        <cMuted>8a94a0ff</cMuted>
        <cStar>f5c518ff</cStar>
    </variables>
</theme>
