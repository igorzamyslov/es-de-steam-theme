<theme>
    <view name="gamelist">
        <!-- panel background -->
        <image name="detailPanelBg">
            <pos>0.70 0</pos>
            <size>0.30 1</size>
            <path>./../assets/ui/panel.svg</path>
            <zIndex>10</zIndex>
        </image>

        <!-- media renders directly (no backing plate); has its own rounded corners.
             screenshot/marquee shown first; video auto-plays after a delay -->
        <video name="detailMedia">
            <pos>0.85 0.135</pos>
            <origin>0.5 0.5</origin>
            <maxSize>0.262 0.165</maxSize>
            <imageMaxSize>0.262 0.165</imageMaxSize>
            <imageType>${detailMediaType}</imageType>
            <default>./../assets/ui/capsule-placeholder.svg</default>
            <delay>2.5</delay>
            <fadeInTime>0.6</fadeInTime>
            <pillarboxes>false</pillarboxes>
            <imageCornerRadius>${rad}</imageCornerRadius>
            <videoCornerRadius>${rad}</videoCornerRadius>
            <zIndex>20</zIndex>
        </video>

        <!-- title: wraps up to ~3 lines so long names fit instead of truncating -->
        <text name="detailTitle">
            <pos>0.72 0.235</pos>
            <size>0.26 0.115</size>
            <metadata>name</metadata>
            <container>false</container>
            <fontPath>${fontDisplay}</fontPath>
            <fontSize>0.026</fontSize>
            <color>${cText}</color>
            <zIndex>20</zIndex>
        </text>

        <!-- rating (gold) -->
        <rating name="detailRating">
            <pos>0.72 0.358</pos>
            <size>0 0.024</size>
            <color>${cStar}</color>
            <hideIfZero>false</hideIfZero>
            <zIndex>20</zIndex>
        </rating>
        <!-- favorite indicator: only renders for favorited games -->
        <badges name="detailFav">
            <pos>0.978 0.358</pos><origin>1 0</origin>
            <size>0.07 0.026</size>
            <slots>favorite</slots>
            <lines>1</lines><itemsPerLine>1</itemsPerLine>
            <badgeIconColor>${cStar}</badgeIconColor>
            <zIndex>20</zIndex>
        </badges>

        <!-- metadata: label + value share the SAME y so they align; values are single-line -->
        <text name="detailGenreKey"><pos>0.72 0.40</pos><size>0.08 0.024</size><text>Genre</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailGenre"><pos>0.805 0.40</pos><size>0.175 0.024</size><metadata>genre</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailDevKey"><pos>0.72 0.432</pos><size>0.08 0.024</size><text>Developer</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailDeveloper"><pos>0.805 0.432</pos><size>0.175 0.024</size><metadata>developer</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailPlayersKey"><pos>0.72 0.464</pos><size>0.08 0.024</size><text>Players</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailPlayers"><pos>0.805 0.464</pos><size>0.175 0.024</size><metadata>players</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailReleasedKey"><pos>0.72 0.496</pos><size>0.08 0.024</size><text>Released</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <datetime name="detailReleased"><pos>0.805 0.496</pos><size>0.175 0.024</size><metadata>releasedate</metadata><format>%Y</format>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cText2}</color><zIndex>20</zIndex></datetime>

        <!-- description: the only scroll region; ends above the Play button -->
        <text name="detailDescLabel"><pos>0.72 0.54</pos><size>0.26 0.022</size><text>Description</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.0185</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailDesc">
            <pos>0.72 0.565</pos>
            <size>0.26 0.25</size>
            <metadata>description</metadata>
            <container>true</container>
            <containerType>vertical</containerType>
            <fontPath>${fontRegular}</fontPath>
            <fontSize>0.0185</fontSize>
            <color>${cText2}</color>
            <lineSpacing>1.5</lineSpacing>
            <zIndex>20</zIndex>
        </text>

        <!-- decorative Play affordance (launch is via A); rounded via the property (matches grid) -->
        <image name="detailPlayBg">
            <pos>0.72 0.845</pos><size>0.26 0.058</size>
            <path>./../assets/ui/play-button.svg</path>
            <cornerRadius>${radButton}</cornerRadius><zIndex>20</zIndex>
        </image>
        <text name="detailPlayLabel">
            <pos>0.85 0.874</pos><origin>0.5 0.5</origin>
            <text>PLAY</text><fontPath>${fontDisplay}</fontPath>
            <fontSize>0.021</fontSize><color>102b06ff</color>
            <horizontalAlignment>center</horizontalAlignment><zIndex>21</zIndex>
        </text>
    </view>
</theme>
