<theme>
    <!-- Desktop detail panel. Panel runs flush to the right screen edge; x/width, content x, key
         column width and value column come from scale.xml per font size. Vertical structure:
         TITLE at the top (multi-line) -> VIDEO fills the gap below it -> bottom block anchored low
         (stars -> metadata -> ~4-line description -> Play). Positions are fixed and sized for the
         largest fonts so smaller sizes just gain breathing room. -->
    <view name="gamelist">
        <image name="detailPanelBg">
            <pos>${pPanelX} 0</pos><size>${pPanelW} 1</size>
            <path>./../assets/ui/panel.svg</path><zIndex>10</zIndex>
        </image>

        <!-- title: top of the column, wraps to multiple lines -->
        <text name="detailTitle">
            <pos>${pContentX} 0.064</pos><size>${pInnerW} ${pTitleH}</size>
            <!-- single-line marquee: constant height -> video below always fills the rest, no gap -->
            <metadata>name</metadata><container>true</container><containerType>horizontal</containerType>
            <fontPath>${fontDisplay}</fontPath><fontSize>${fsTitle}</fontSize>
            <verticalAlignment>top</verticalAlignment>
            <color>${cText}</color><zIndex>20</zIndex>
        </text>

        <!-- media: fills the space between the title and the bottom block; centered horizontally -->
        <video name="detailMedia">
            <pos>${pPanelCX} ${pVideoY}</pos><origin>0.5 0</origin>
            <maxSize>${pInnerW} ${pVideoH}</maxSize><imageMaxSize>${pInnerW} ${pVideoH}</imageMaxSize>
            <imageType>${detailMediaType}</imageType>
            <default>./../assets/ui/capsule-placeholder.svg</default>
            <delay>2.5</delay><fadeInTime>0.6</fadeInTime>
            <pillarboxes>false</pillarboxes>
            <imageCornerRadius>${rad}</imageCornerRadius><videoCornerRadius>${rad}</videoCornerRadius>
            <zIndex>20</zIndex>
        </video>

        <!-- bottom block: stars -> metadata -> description -> Play -->
        <rating name="detailRating">
            <pos>${pContentX} 0.445</pos><size>0 0.024</size>
            <color>${cStar}</color><hideIfZero>false</hideIfZero><zIndex>20</zIndex>
        </rating>
        <badges name="detailFav">
            <pos>0.972 0.445</pos><origin>1 0</origin><size>0.07 0.026</size>
            <slots>favorite</slots><lines>1</lines><itemsPerLine>1</itemsPerLine>
            <badgeIconColor>${cStar}</badgeIconColor><zIndex>20</zIndex>
        </badges>

        <text name="detailGenreKey"><pos>${pContentX} 0.485</pos><size>${pKeyW} 0.024</size><text>Genre</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailGenre"><pos>${pValueX} 0.485</pos><size>${pValueW} 0.024</size><metadata>genre</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailDevKey"><pos>${pContentX} 0.523</pos><size>${pKeyW} 0.024</size><text>Developer</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailDeveloper"><pos>${pValueX} 0.523</pos><size>${pValueW} 0.024</size><metadata>developer</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailPlayersKey"><pos>${pContentX} 0.561</pos><size>${pKeyW} 0.024</size><text>Players</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailPlayers"><pos>${pValueX} 0.561</pos><size>${pValueW} 0.024</size><metadata>players</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailReleasedKey"><pos>${pContentX} 0.599</pos><size>${pKeyW} 0.024</size><text>Released</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <datetime name="detailReleased"><pos>${pValueX} 0.599</pos><size>${pValueW} 0.024</size><metadata>releasedate</metadata><format>%Y</format>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cText2}</color><zIndex>20</zIndex></datetime>

        <text name="detailDescLabel"><pos>${pContentX} 0.645</pos><size>${pInnerW} 0.022</size><text>Description</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMeta}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailDesc">
            <pos>${pContentX} 0.675</pos><size>${pInnerW} 0.155</size>
            <metadata>description</metadata><container>true</container><containerType>vertical</containerType>
            <fontPath>${fontRegular}</fontPath><fontSize>${fsMeta}</fontSize>
            <color>${cText2}</color><lineSpacing>1.35</lineSpacing><zIndex>20</zIndex>
        </text>

        <image name="detailPlayBg">
            <pos>${pContentX} 0.845</pos><size>${pInnerW} 0.058</size>
            <path>./../assets/ui/play-button.svg</path>
            <cornerRadius>${radButton}</cornerRadius><zIndex>20</zIndex>
        </image>
        <image name="detailPlayIcon">
            <pos>${pPlayIconX} 0.874</pos><origin>0.5 0.5</origin><size>0.022 0.036</size>
            <path>./../assets/ui/play-triangle.svg</path><zIndex>21</zIndex>
        </image>
        <text name="detailPlayLabel">
            <pos>${pPlayLabelX} 0.874</pos><origin>0 0.5</origin>
            <text>Play</text><fontPath>${fontSemiBold}</fontPath>
            <fontSize>${fsButton}</fontSize><color>ffffffff</color>
            <horizontalAlignment>left</horizontalAlignment><zIndex>21</zIndex>
        </text>
    </view>
</theme>
