<theme>
    <!-- Phone / ultrawide gamelist banner. Included ONLY for phone aspect ratios by
         gamelist_grid.xml (wrapped in an <aspectRatio> block). Full-width hero media across the
         top with the focused game's title + compact meta overlaid bottom-left. No detail panel. -->
    <view name="gamelist">
        <!-- hero media: ${detailMediaType} (marquee/screenshot per variant) -> cover -> placeholder.
             cover-cropped to fill the full-width banner; video auto-plays after the delay. -->
        <video name="bannerMedia">
            <pos>0 0.056</pos><origin>0 0</origin>
            <cropSize>1 0.30</cropSize><cropPos>0.5 0.5</cropPos>
            <imageType>${detailMediaType}, cover</imageType>
            <defaultImage>./../assets/ui/art-placeholder.svg</defaultImage>
            <delay>2.5</delay><fadeInTime>0.6</fadeInTime>
            <pillarboxes>false</pillarboxes>
            <zIndex>5</zIndex>
        </video>
        <!-- bottom scrim for title/meta legibility over the media -->
        <image name="bannerScrim">
            <pos>0 0.196</pos><size>1 0.16</size>
            <path>./../assets/ui/rail-scrim.svg</path>
            <zIndex>6</zIndex>
        </image>
        <!-- focused game title -->
        <text name="bannerTitle">
            <pos>0.035 0.246</pos><size>0.82 0.06</size>
            <metadata>name</metadata><container>false</container>
            <fontPath>${fontDisplay}</fontPath><fontSize>${fsHeader}</fontSize>
            <color>${cText}</color><zIndex>10</zIndex>
        </text>
        <!-- compact meta line: genre · year + rating + favorite. (developer/players omitted -
             per-game metadata can't be collapsed into one clean middot line like the system spec line.) -->
        <text name="bannerGenre"><pos>0.035 0.312</pos><size>0.14 0.03</size><metadata>genre</metadata><defaultValue>:space:</defaultValue>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsLabel}</fontSize><color>${cText2}</color><zIndex>10</zIndex></text>
        <text name="bannerSep"><pos>0.178 0.312</pos><size>0.015 0.03</size><text>·</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsLabel}</fontSize><color>${cMuted}</color><zIndex>10</zIndex></text>
        <datetime name="bannerYear"><pos>0.197 0.312</pos><size>0.08 0.03</size><metadata>releasedate</metadata><format>%Y</format><defaultValue>:space:</defaultValue>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsLabel}</fontSize><color>${cText2}</color><zIndex>10</zIndex></datetime>
        <rating name="bannerRating"><pos>0.30 0.312</pos><size>0 0.028</size>
            <color>${cStar}</color><hideIfZero>true</hideIfZero><zIndex>10</zIndex></rating>
        <badges name="bannerFav"><pos>0.42 0.31</pos><size>0.05 0.03</size>
            <slots>favorite</slots><lines>1</lines><itemsPerLine>1</itemsPerLine>
            <badgeIconColor>${cStar}</badgeIconColor><zIndex>10</zIndex></badges>
    </view>
</theme>
