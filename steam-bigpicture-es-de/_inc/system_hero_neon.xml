<theme>
    <include>./helpsystem.xml</include>
    <include>./status.xml</include>
    <!-- official ES-DE per-system metadata: ${systemName} (short name) + ${systemColor} (tint); full coverage, _default fallback -->
    <include>./../system-metadata/_default.xml</include>
    <include>./../system-metadata/${system.theme}.xml</include>
    <!-- targeted overrides for ES-DE short names that collapse to the manufacturer (e.g. nes -> NES) -->
    <include>./name-overrides/${system.theme}.xml</include>
    <view name="system">
        <!-- atmospheric background plate (per-system bg added in Task 17) -->
        <image name="heroBg">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/hero-bg.svg</path>
            <zIndex>1</zIndex>
        </image>
        <!-- per-system mood tint overlay -->
        <image name="heroTint">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/tint.svg</path>
            <color>${systemColor}cc</color>
            <zIndex>2</zIndex>
        </image>
        <!-- big focus-tracked system logo as the "neon" hero subject -->
        <image name="heroLogo">
            <pos>0.70 0.40</pos><origin>0.5 0.5</origin>
            <maxSize>0.44 0.46</maxSize>
            <path>./../system-logos/system-logo-white/${system.theme}.svg</path>
            <default>./../assets/icons/fallback.svg</default>
            <color>e8edf2ff</color>
            <zIndex>5</zIndex>
        </image>
        <!-- darken the lower area so the icon rail stays legible over the colored hero -->
        <image name="railScrim">
            <pos>0 0.55</pos><size>1 0.45</size>
            <path>./../assets/ui/rail-scrim.svg</path>
            <zIndex>6</zIndex>
        </image>
        <!-- left scrim for text legibility -->
        <image name="heroScrim">
            <pos>0 0</pos><size>0.62 1</size>
            <path>./../assets/ui/scrim-left.svg</path>
            <zIndex>8</zIndex>
        </image>
        <!-- system name + count -->
        <!-- primary: official short name (${systemName}); falls back to full name for un-curated systems -->
        <text name="sysName">
            <pos>0.05 0.55</pos><size>0.60 0.095</size>
            <text>${systemName}</text>
            <container>false</container>
            <fontPath>${fontExtraBold}</fontPath><fontSize>0.052</fontSize>
            <color>${cText}</color><zIndex>10</zIndex>
        </text>
        <!-- secondary: manufacturer (non-redundant with the system name; ${systemManufacturer} from metadata) -->
        <text name="sysFull">
            <pos>0.05 0.645</pos><size>0.62 0.04</size>
            <text>${systemManufacturer}</text>
            <container>false</container>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.020</fontSize>
            <color>${cText2}</color><zIndex>10</zIndex>
        </text>
        <text name="sysCount">
            <pos>0.05 0.70</pos><size>0.5 0.05</size>
            <systemdata>gamecount</systemdata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.022</fontSize>
            <color>${cText2}</color><zIndex>10</zIndex>
        </text>
        <!-- bottom rail of system icons -->
        <carousel name="rail">
            <pos>0 0.75</pos><size>1 0.15</size>
            <type>horizontal</type>
            <staticImage>./../system-controllers-outline/${system.theme}.svg</staticImage>
            <defaultImage>./../assets/icons/fallback.svg</defaultImage>
            <maxItemCount>9</maxItemCount>
            <itemSize>0.085 0.12</itemSize>
            <itemScale>1.18</itemScale>
            <imageColor>ccd6e0ff</imageColor>
            <imageSelectedColor>ffffffff</imageSelectedColor>
            <color>00000000</color>
            <text>${system.fullName}</text>
            <textColor>00000000</textColor>
            <zIndex>40</zIndex>
        </carousel>
    </view>
</theme>
