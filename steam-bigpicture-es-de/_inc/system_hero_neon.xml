<theme>
    <include>./helpsystem.xml</include>
    <include>./status.xml</include>
    <!-- official ES-DE per-system metadata FIRST: defines ${systemName} + ${systemColor} (hero
         tint + platform tab underline + focused icon); must precede section-state, which reads it.
         section-accent below overrides ${systemColor} for the auto-collections. -->
    <include>./../system-metadata/_default.xml</include>
    <include>./../system-metadata/${system.theme}.xml</include>
    <!-- targeted overrides for ES-DE short names that collapse to the manufacturer (e.g. nes -> NES) -->
    <include>./name-overrides/${system.theme}.xml</include>
    <!-- collection accent: overrides ${systemColor} for the auto-collections (after metadata) -->
    <include>./section-accent/${system.theme}.xml</include>
    <!-- spec-line composition (after metadata so the nested vars resolve) -->
    <include>./spec-overrides/_default.xml</include>
    <include>./spec-overrides/${system.theme}.xml</include>
    <!-- section-strip highlight state: which tab is active. Platform underline = ${systemColor};
         the three collections use ${cAccent}. _default first, then per-collection override. -->
    <include>./section-state/_default.xml</include>
    <include>./section-state/${system.theme}.xml</include>
    <!-- Steam-style persistent section nav (consumes the section-state vars above) -->
    <include>./section-strip.xml</include>
    <!-- shared colour-logo capsule rail (root-level: it carries its own <view name="system">,
         which ES-DE merges into this view; an <include> is only valid at the theme root). -->
    <include>./system_rail.xml</include>
    <view name="system">
        <!-- atmospheric background plate (per-system bg added in Task 17) -->
        <image name="heroBg">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/hero-bg.svg</path>
            <zIndex>1</zIndex>
        </image>
        <!-- per-system mood tint overlay -->
        <image name="heroTint">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/tint.svg</path>
            <color>${systemColor}cc</color>
            <zIndex>2</zIndex>
        </image>
        <!-- per-system colour bloom behind the logo: white asset multiplied by ${systemColor}
             so the focused system's colour blooms across the hero (radial isn't an engine
             primitive; this is a baked diagonal-linear glow asset). -->
        <image name="heroBloom">
            <pos>0.45 0</pos><size>0.55 1</size>
            <path>./../assets/ui/hero-bloom.svg</path>
            <color>${systemColor}3a</color>
            <zIndex>3</zIndex>
        </image>
        <!-- big focus-tracked system logo as the "neon" hero subject — full colour (was the
             flat white logo); no <color> tint so the brand colours render. -->
        <image name="heroLogo">
            <pos>0.70 0.40</pos><origin>0.5 0.5</origin>
            <maxSize>0.52 0.48</maxSize>
            <path>./../system-logos/system-logo-color/${system.theme}.svg</path>
            <default>./../assets/icons/fallback.svg</default>
            <zIndex>5</zIndex>
        </image>
        <!-- darken the lower area so the icon rail stays legible over the colored hero -->
        <image name="railScrim">
            <pos>0 0.55</pos><size>1 0.45</size>
            <path>./../assets/ui/rail-scrim.svg</path>
            <zIndex>6</zIndex>
        </image>
        <!-- left scrim for text legibility -->
        <image name="heroScrim">
            <pos>0 0</pos><size>0.62 1</size>
            <path>./../assets/ui/scrim-left.svg</path>
            <zIndex>8</zIndex>
        </image>
        <!-- bottom-left info panel: name · spec line · count · description (inhabit the void) -->
        <text name="sysName">
            <pos>0.05 ${heroNameY}</pos><size>0.60 0.095</size>
            <text>${systemName}</text>
            <container>false</container>
            <fontPath>${fontDisplay}</fontPath><fontSize>${fsHero}</fontSize>
            <color>${cText}</color><zIndex>10</zIndex>
        </text>
        <!-- spec line: hardware type · manufacturer · year; collection-type systems collapse to just the type -->
        <text name="sysSpec">
            <pos>0.05 ${heroSpecY}</pos><size>0.62 0.04</size>
            <text>${specLine}</text>
            <container>false</container>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsLabel}</fontSize>
            <color>${cText2}</color><zIndex>10</zIndex>
        </text>
        <text name="sysCount">
            <pos>0.05 ${heroCountY}</pos><size>0.5 0.05</size>
            <systemdata>gamecount</systemdata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsCount}</fontSize>
            <color>${cText2}</color><zIndex>10</zIndex>
        </text>
        <!-- system description fills the empty space; scrolls if long; legible over the left scrim -->
        <text name="sysDesc">
            <pos>0.05 ${heroDescY}</pos><size>0.46 ${heroDescH}</size>
            <text>${systemDescription}</text>
            <container>true</container><containerType>vertical</containerType>
            <fontPath>${fontRegular}</fontPath><fontSize>${fsMeta}</fontSize>
            <color>${cText2}</color><lineSpacing>1.4</lineSpacing><zIndex>10</zIndex>
        </text>
    </view>
</theme>
