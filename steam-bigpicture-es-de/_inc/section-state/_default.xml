<theme>
    <!-- Section-strip nav DEFAULTS: Platforms active (most systems are consoles).
         Included before section-state/${system.theme}.xml so a focused collection's
         override wins (last include wins; mirrors the system-metadata _default pattern).
         active text = e8edf2 (cText), inactive = 8f98a0 (readable grey);
         active underline: Platforms = ${systemColor} (per-platform); the three collections use
         ${cAccent} (set in their own overrides). The focused rail icon uses ${systemColor} directly. -->
    <variables>
        <secTxtLibrary>8f98a0ff</secTxtLibrary>
        <secTxtRecent>8f98a0ff</secTxtRecent>
        <secTxtFav>8f98a0ff</secTxtFav>
        <secTxtPlat>e8edf2ff</secTxtPlat>
        <secUnLibrary>00000000</secUnLibrary>
        <secUnRecent>00000000</secUnRecent>
        <secUnFav>00000000</secUnFav>
        <secUnPlat>${systemColor}ff</secUnPlat>
    </variables>
</theme>
