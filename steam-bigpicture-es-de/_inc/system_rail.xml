<theme>
    <!-- Shared system-view rail: a Steam-style shelf of full-colour system-logo capsules.
         The capsule plate + colour logo are baked into one asset per system
         (system-logos/system-capsule/${system.theme}.svg, generated by
         scripts/gen-system-capsules.py); _fallback.svg covers systems with no colour logo.

         Focus is conveyed by scale (itemScale) + the selected item at full brightness
         while the rest are dimmed/desaturated. The carousel has NO per-item plate and NO
         selectorImage/focus frame, and cannot style an item by game count — so there is no
         focus ring and no per-tile "empty" treatment here; emptiness shows in the hero count.

         imageColor is intentionally UNSET: the carousel default (FFFFFF) is "no colour
         shift", so the multicolour logos render in their native brand colours. Feeding a
         per-system colour here would multiply (tint) the whole capsule and reintroduce the
         per-item carousel-tint glitch. -->
    <view name="system">
        <!-- shelf label above the rail (Steam-style) -->
        <text name="railLabel">
            <pos>0.05 0.715</pos><size>0.4 0.03</size>
            <text>ALL SYSTEMS</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsTab}</fontSize>
            <letterCase>uppercase</letterCase>
            <color>${cMuted}</color><zIndex>40</zIndex>
        </text>
        <carousel name="rail">
            <pos>0 0.75</pos><size>1 0.15</size>
            <type>horizontal</type>
            <staticImage>./../system-logos/system-capsule/${system.theme}.svg</staticImage>
            <defaultImage>./../system-logos/system-capsule/_fallback.svg</defaultImage>
            <maxItemCount>7</maxItemCount>
            <itemSize>0.15 0.133</itemSize>
            <itemScale>1.08</itemScale>
            <imageFit>contain</imageFit>
            <imageCornerRadius>${radTile}</imageCornerRadius>
            <imageSelectedColor>ffffffff</imageSelectedColor>
            <!-- solid capsules (no see-through): unfocused recede via dimming + desaturation,
                 not transparency. Focused = full brightness + itemScale. Matches the grid. -->
            <unfocusedItemOpacity>1.0</unfocusedItemOpacity>
            <unfocusedItemSaturation>0.72</unfocusedItemSaturation>
            <unfocusedItemDimming>0.74</unfocusedItemDimming>
            <color>00000000</color>
            <text>${system.fullName}</text>
            <textColor>00000000</textColor>
            <zIndex>40</zIndex>
        </carousel>
    </view>
</theme>
