<theme>
    <!-- Type scale + grid sizing per Theme Font Size. Included before the element files so these
         variables are defined before use (ES-DE resolves in order).
         Tiers: medium (baseline) -> large (big jump) -> x-large (bigger). clock + list are
         deliberately tamed (they read too large when scaled with everything else). -->
    <fontSize name="medium">
        <variables>
            <fsHero>0.052</fsHero><fsHeader>0.032</fsHeader><fsList>0.026</fsList>
            <fsClock>0.024</fsClock><fsTitleWide>0.028</fsTitleWide><fsTitle>0.026</fsTitle>
            <fsCount>0.022</fsCount><fsButton>0.021</fsButton><fsLabel>0.020</fsLabel>
            <fsMetaWide>0.019</fsMetaWide><fsMeta>0.0185</fsMeta><fsTab>0.018</fsTab>
            <gridItemY>0.20</gridItemY><gridSpacing>0.010 0.016</gridSpacing>
        </variables>
    </fontSize>
    <fontSize name="large">
        <variables>
            <fsHero>0.064</fsHero><fsHeader>0.044</fsHeader><fsList>0.032</fsList>
            <fsClock>0.027</fsClock><fsTitleWide>0.038</fsTitleWide><fsTitle>0.036</fsTitle>
            <fsCount>0.030</fsCount><fsButton>0.028</fsButton><fsLabel>0.027</fsLabel>
            <fsMetaWide>0.026</fsMetaWide><fsMeta>0.025</fsMeta><fsTab>0.025</fsTab>
            <gridItemY>0.27</gridItemY><gridSpacing>0.013 0.021</gridSpacing>
        </variables>
    </fontSize>
    <fontSize name="x-large">
        <variables>
            <fsHero>0.074</fsHero><fsHeader>0.052</fsHeader><fsList>0.038</fsList>
            <fsClock>0.030</fsClock><fsTitleWide>0.044</fsTitleWide><fsTitle>0.042</fsTitle>
            <fsCount>0.035</fsCount><fsButton>0.032</fsButton><fsLabel>0.031</fsLabel>
            <fsMetaWide>0.030</fsMetaWide><fsMeta>0.029</fsMeta><fsTab>0.029</fsTab>
            <gridItemY>0.31</gridItemY><gridSpacing>0.015 0.024</gridSpacing>
        </variables>
    </fontSize>

    <!-- grid item WIDTH per aspect x size: itemX = itemY * (2/3) / (W:H) keeps tiles ~2:3 portrait -->
    <aspectRatio name="4:3, 5:4">
        <fontSize name="medium"><variables><gridItemX>0.100</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.135</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.155</gridItemX></variables></fontSize>
    </aspectRatio>
    <aspectRatio name="16:10">
        <fontSize name="medium"><variables><gridItemX>0.083</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.113</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.129</gridItemX></variables></fontSize>
    </aspectRatio>
    <aspectRatio name="16:9">
        <fontSize name="medium"><variables><gridItemX>0.075</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.101</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.116</gridItemX></variables></fontSize>
    </aspectRatio>
    <!-- phone aspects kept SEPARATE: each needs its own width for a true 2:3 cell -->
    <aspectRatio name="19.5:9">
        <fontSize name="medium"><variables><gridItemX>0.062</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.083</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.095</gridItemX></variables></fontSize>
    </aspectRatio>
    <aspectRatio name="20:9">
        <fontSize name="medium"><variables><gridItemX>0.060</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.081</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.093</gridItemX></variables></fontSize>
    </aspectRatio>
    <aspectRatio name="21:9">
        <fontSize name="medium"><variables><gridItemX>0.057</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.077</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.089</gridItemX></variables></fontSize>
    </aspectRatio>
</theme>
