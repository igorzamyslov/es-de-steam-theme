<theme>
    <!-- Type scale + grid sizing per Theme Font Size. Included before the element files so these
         variables are defined before use. clock + list are deliberately tamed.
         NOTE: the grid uses itemScale 1.0 (focus = frame + dimming), so fractionalRows=false snaps
         rows to itemY exactly (itemScale>1 would inflate each row's reserved height and drop a row). -->

    <!-- grid REGION defaults = desktop side-panel layout. Symmetric padding P=0.035:
         grid x=0.035, fixed block width 0.63, P gap, panel x=0.70 w=0.265 (right edge 0.965 = 1-P). -->
    <variables>
        <gridPos>0.035 0.155</gridPos>
        <gridFractional>false</gridFractional>
    </variables>

    <!-- itemY derived for an exact whole-row fit in ~0.765 available height: 3 rows (medium/large),
         2 rows (x-large). gridSize = fixed 0.63 block x region height. -->
    <fontSize name="medium">
        <variables>
            <fsHero>0.052</fsHero><fsHeader>0.032</fsHeader><fsList>0.026</fsList>
            <fsClock>0.024</fsClock><fsTitleWide>0.028</fsTitleWide><fsTitle>0.026</fsTitle>
            <fsCount>0.022</fsCount><fsButton>0.021</fsButton><fsLabel>0.020</fsLabel>
            <fsMetaWide>0.019</fsMetaWide><fsMeta>0.0185</fsMeta><fsTab>0.018</fsTab>
            <gridItemY>0.242</gridItemY><gridSpacing>0.010 0.016</gridSpacing>
            <gridSize>0.596 0.764</gridSize>
            <heroNameY>0.48</heroNameY><heroSpecY>0.595</heroSpecY><heroCountY>0.635</heroCountY>
            <heroDescY>0.685</heroDescY><heroDescH>0.062</heroDescH>
            <!-- detail panel (6 grid cols on 16:9): x/width + content x + media width -->
            <pPanelX>0.666</pPanelX><pPanelW>0.299</pPanelW><pContentX>0.686</pContentX><pValueX>0.771</pValueX>
            <pInnerW>0.259</pInnerW><pValueW>0.174</pValueW><pMediaW>0.259</pMediaW>
            <pPlayIconX>0.7975</pPlayIconX><pPlayLabelX>0.8125</pPlayLabelX>
        </variables>
    </fontSize>
    <fontSize name="large">
        <variables>
            <fsHero>0.064</fsHero><fsHeader>0.044</fsHeader><fsList>0.032</fsList>
            <fsClock>0.027</fsClock><fsTitleWide>0.038</fsTitleWide><fsTitle>0.036</fsTitle>
            <fsCount>0.030</fsCount><fsButton>0.028</fsButton><fsLabel>0.027</fsLabel>
            <fsMetaWide>0.026</fsMetaWide><fsMeta>0.025</fsMeta><fsTab>0.025</fsTab>
            <gridItemY>0.241</gridItemY><gridSpacing>0.013 0.018</gridSpacing>
            <gridSize>0.506 0.765</gridSize>
            <heroNameY>0.44</heroNameY><heroSpecY>0.555</heroSpecY><heroCountY>0.595</heroCountY>
            <heroDescY>0.645</heroDescY><heroDescH>0.10</heroDescH>
            <!-- detail panel (5 grid cols on 16:9): widest panel -> biggest video -->
            <pPanelX>0.576</pPanelX><pPanelW>0.389</pPanelW><pContentX>0.596</pContentX><pValueX>0.681</pValueX>
            <pInnerW>0.349</pInnerW><pValueW>0.264</pValueW><pMediaW>0.349</pMediaW>
            <pPlayIconX>0.7525</pPlayIconX><pPlayLabelX>0.7675</pPlayLabelX>
        </variables>
    </fontSize>
    <fontSize name="x-large">
        <variables>
            <fsHero>0.074</fsHero><fsHeader>0.052</fsHeader><fsList>0.038</fsList>
            <fsClock>0.030</fsClock><fsTitleWide>0.044</fsTitleWide><fsTitle>0.042</fsTitle>
            <fsCount>0.035</fsCount><fsButton>0.032</fsButton><fsLabel>0.031</fsLabel>
            <fsMetaWide>0.030</fsMetaWide><fsMeta>0.029</fsMeta><fsTab>0.029</fsTab>
            <gridItemY>0.370</gridItemY><gridSpacing>0.015 0.020</gridSpacing>
            <gridSize>0.602 0.764</gridSize>
            <heroNameY>0.40</heroNameY><heroSpecY>0.515</heroSpecY><heroCountY>0.565</heroCountY>
            <heroDescY>0.615</heroDescY><heroDescH>0.13</heroDescH>
            <!-- detail panel (4 grid cols on 16:9) -->
            <pPanelX>0.672</pPanelX><pPanelW>0.293</pPanelW><pContentX>0.692</pContentX><pValueX>0.777</pValueX>
            <pInnerW>0.253</pInnerW><pValueW>0.168</pValueW><pMediaW>0.253</pMediaW>
            <pPlayIconX>0.8005</pPlayIconX><pPlayLabelX>0.8155</pPlayLabelX>
        </variables>
    </fontSize>

    <!-- grid item WIDTH per aspect x size: itemX = itemY * (2/3) / (W:H) keeps tiles true 2:3 portrait. -->
    <aspectRatio name="4:3, 5:4">
        <fontSize name="medium"><variables><gridItemX>0.121</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.1205</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.185</gridItemX></variables></fontSize>
    </aspectRatio>
    <aspectRatio name="16:10">
        <fontSize name="medium"><variables><gridItemX>0.1008</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.1004</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.1542</gridItemX></variables></fontSize>
    </aspectRatio>
    <aspectRatio name="16:9">
        <fontSize name="medium"><variables><gridItemX>0.0907</gridItemX></variables></fontSize>
        <fontSize name="large"><variables><gridItemX>0.0904</gridItemX></variables></fontSize>
        <fontSize name="x-large"><variables><gridItemX>0.1388</gridItemX></variables></fontSize>
    </aspectRatio>

    <!-- PHONE / ULTRAWIDE: hero-banner layout. Grid full-width below banner, 2 fixed rows of
         ~10 medium 2:3 capsules (itemY accounts for itemScale 1.0). -->
    <aspectRatio name="19.5:9">
        <variables>
            <gridPos>0.035 0.388</gridPos><gridSize>0.93 0.532</gridSize>
            <gridFractional>false</gridFractional>
            <gridItemY>0.256</gridItemY><gridSpacing>0.010 0.016</gridSpacing>
            <gridItemX>0.0788</gridItemX>
        </variables>
    </aspectRatio>
    <aspectRatio name="20:9">
        <variables>
            <gridPos>0.035 0.388</gridPos><gridSize>0.93 0.532</gridSize>
            <gridFractional>false</gridFractional>
            <gridItemY>0.256</gridItemY><gridSpacing>0.010 0.016</gridSpacing>
            <gridItemX>0.0768</gridItemX>
        </variables>
    </aspectRatio>
    <aspectRatio name="21:9">
        <variables>
            <gridPos>0.035 0.388</gridPos><gridSize>0.93 0.532</gridSize>
            <gridFractional>false</gridFractional>
            <gridItemY>0.256</gridItemY><gridSpacing>0.010 0.016</gridSpacing>
            <gridItemX>0.0732</gridItemX>
        </variables>
    </aspectRatio>
</theme>
