<theme>
    <include>./helpsystem.xml</include>
    <include>./status.xml</include>
    <include>./detail_wide.xml</include>
    <view name="gamelist">
        <!-- Steam library backdrop (dark blue-grey, not black) behind the whole view -->
        <image name="gridBg">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/grid-bg.svg</path>
            <zIndex>1</zIndex>
        </image>
        <!-- header sits below the section-strip top bar (which ends at y 0.056) -->
        <text name="glHeader">
            <pos>0.035 0.064</pos><size>0.42 0.05</size>
            <!-- use ${systemName} (matches the system-view name + honours the collection renames) -->
            <text>${systemName}</text>
            <fontPath>${fontDisplay}</fontPath><fontSize>${fsHeader}</fontSize>
            <color>${cText}</color><zIndex>20</zIndex>
        </text>
        <gamelistinfo name="glCount">
            <pos>0.035 ${glCountY}</pos><size>0.3 0.03</size>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsTab}</fontSize>
            <color>${cText2}</color><zIndex>20</zIndex>
        </gamelistinfo>
        <!-- list occupies the left half; the wider detail panel fills the right half -->
        <textlist name="gameList">
            <pos>${listTop}</pos><size>0.43 0.74</size>
            <primaryColor>${cText2}</primaryColor>
            <secondaryColor>${cText2}</secondaryColor>
            <selectedColor>${cText}</selectedColor>
            <selectedSecondaryColor>${cText}</selectedSecondaryColor>
            <!-- full-line highlight: the selector bar spans the whole row width -->
            <selectorColor>27313dff</selectorColor>
            <selectorHeight>0.05</selectorHeight>
            <fontPath>${fontSemiBold}</fontPath>
            <fontSize>${fsList}</fontSize>
            <horizontalMargin>0.014</horizontalMargin>
            <lineSpacing>1.7</lineSpacing>
            <indicators>symbols</indicators>
            <zIndex>30</zIndex>
        </textlist>
    </view>
</theme>
