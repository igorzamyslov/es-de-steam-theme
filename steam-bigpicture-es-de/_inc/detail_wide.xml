<theme>
    <!-- Wide detail panel for the LIST gamelist (right half, x 0.48-1.0). Same structure as the grid
         panel (detail.xml): TITLE top (multi-line, top-aligned) -> VIDEO fills the gap below it ->
         bottom block anchored low (stars -> metadata -> ~4-line description -> left-aligned Play).
         Title height + video anchor come from the pw* scale variables; the bottom block is fixed and
         sized for the largest fonts. Content runs x 0.51 -> 0.98 (center 0.745). -->
    <view name="gamelist">
        <image name="detailPanelBg">
            <pos>0.48 0</pos><size>0.52 1</size>
            <path>./../assets/ui/panel.svg</path><zIndex>10</zIndex>
        </image>

        <!-- title: top of the panel, wraps to multiple lines -->
        <text name="detailTitle">
            <pos>0.51 0.064</pos><size>0.47 ${pwTitleH}</size>
            <!-- single-line marquee: constant height -> video below always fills the rest, no gap -->
            <metadata>name</metadata><container>true</container><containerType>horizontal</containerType>
            <fontPath>${fontDisplay}</fontPath><fontSize>${fsTitleWide}</fontSize>
            <verticalAlignment>top</verticalAlignment>
            <color>${cText}</color><zIndex>20</zIndex>
        </text>

        <!-- media: fills the space between the title and the bottom block; centered horizontally -->
        <video name="detailMedia">
            <pos>0.745 ${pwVideoY}</pos><origin>0.5 0</origin>
            <maxSize>0.47 ${pwVideoH}</maxSize><imageMaxSize>0.47 ${pwVideoH}</imageMaxSize>
            <imageType>${detailMediaType}</imageType>
            <defaultImage>./../assets/ui/capsule-placeholder.svg</defaultImage>
            <delay>${mediaDelay}</delay><fadeInTime>0.6</fadeInTime>
            <pillarboxes>false</pillarboxes>
            <imageCornerRadius>${rad}</imageCornerRadius><videoCornerRadius>${rad}</videoCornerRadius>
            <zIndex>20</zIndex>
        </video>

        <!-- bottom block: stars -> metadata -> description -> Play -->
        <rating name="detailRating">
            <pos>0.51 0.46</pos><size>0 0.024</size>
            <color>${cStar}</color><hideIfZero>false</hideIfZero><zIndex>20</zIndex>
        </rating>
        <badges name="detailFav">
            <pos>0.975 0.46</pos><origin>1 0</origin><size>0.07 0.026</size>
            <slots>favorite</slots><lines>1</lines><itemsPerLine>1</itemsPerLine>
            <badgeIconColor>${cStar}</badgeIconColor><zIndex>20</zIndex>
        </badges>

        <text name="detailGenreKey"><pos>0.51 0.50</pos><size>0.095 0.024</size><text>Genre</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailGenre"><pos>0.61 0.50</pos><size>0.37 0.024</size><metadata>genre</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailDevKey"><pos>0.51 0.538</pos><size>0.095 0.024</size><text>Developer</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailDeveloper"><pos>0.61 0.538</pos><size>0.37 0.024</size><metadata>developer</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailPlayersKey"><pos>0.51 0.576</pos><size>0.095 0.024</size><text>Players</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailPlayers"><pos>0.61 0.576</pos><size>0.37 0.024</size><metadata>players</metadata>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cText2}</color><zIndex>20</zIndex></text>

        <text name="detailReleasedKey"><pos>0.51 0.614</pos><size>0.095 0.024</size><text>Released</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <datetime name="detailReleased"><pos>0.61 0.614</pos><size>0.37 0.024</size><metadata>releasedate</metadata><format>%Y</format>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cText2}</color><zIndex>20</zIndex></datetime>

        <text name="detailDescLabel"><pos>0.51 0.66</pos><size>0.47 0.022</size><text>Description</text>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsMetaWide}</fontSize><color>${cMuted}</color><zIndex>20</zIndex></text>
        <text name="detailDesc">
            <pos>0.51 0.685</pos><size>0.47 0.15</size>
            <metadata>description</metadata><container>true</container><containerType>vertical</containerType>
            <fontPath>${fontRegular}</fontPath><fontSize>${fsMetaWide}</fontSize>
            <color>${cText2}</color><lineSpacing>1.35</lineSpacing><zIndex>20</zIndex>
        </text>

        <image name="detailPlayBg">
            <pos>0.51 0.845</pos><size>0.31 0.058</size>
            <path>./../assets/ui/play-button.svg</path>
            <cornerRadius>${radButton}</cornerRadius><zIndex>20</zIndex>
        </image>
        <!-- left-aligned play triangle + "Play" text, like Steam -->
        <image name="detailPlayIcon">
            <pos>0.535 0.874</pos><origin>0.5 0.5</origin><size>0.022 0.036</size>
            <path>./../assets/ui/play-triangle.svg</path><zIndex>21</zIndex>
        </image>
        <text name="detailPlayLabel">
            <pos>0.555 0.874</pos><origin>0 0.5</origin>
            <text>Play</text><fontPath>${fontSemiBold}</fontPath>
            <fontSize>${fsButton}</fontSize><color>ffffffff</color>
            <horizontalAlignment>left</horizontalAlignment><zIndex>21</zIndex>
        </text>
    </view>
</theme>
