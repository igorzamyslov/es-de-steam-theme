<theme>
    <include>./helpsystem.xml</include>
    <include>./status.xml</include>

    <!-- SHARED: backdrop + the grid (the single navigable/primary element). Region position/size,
         item size, spacing and fractionalRows all come from scale.xml per aspect ratio + font size,
         so the desktop side-panel layout and the phone hero-banner layout reuse one grid element. -->
    <view name="gamelist">
        <image name="gridBg">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/grid-bg.svg</path>
            <zIndex>1</zIndex>
        </image>
        <grid name="capsules">
            <pos>${gridPos}</pos><size>${gridSize}</size>
            <imageType>cover</imageType>
            <!-- no defaultImage: the game name is the automatic fallback for art-less tiles -->
            <textColor>${cText}</textColor>
            <textBackgroundColor>00000000</textBackgroundColor>
            <textRelativeScale>0.86</textRelativeScale>
            <fontPath>${fontSemiBold}</fontPath>
            <fontSize>${fsTab}</fontSize>
            <itemSize>${gridItemX} ${gridItemY}</itemSize>
            <itemSpacing>${gridSpacing}</itemSpacing>
            <!-- itemScale 1.0: fractionalRows snaps rows to itemY exactly; focus = frame + dimming -->
            <itemScale>1.0</itemScale>
            <scaleInwards>true</scaleInwards>
            <fractionalRows>${gridFractional}</fractionalRows>
            <!-- cover inset to 0.91 of the cell -> margin holds the bottom drop shadow; even gap to the frame -->
            <imageFit>cover</imageFit>
            <imageRelativeScale>0.91</imageRelativeScale>
            <imageCornerRadius>${radTile}</imageCornerRadius>
            <backgroundImage>./../assets/ui/capsule-shadow-soft.svg</backgroundImage>
            <backgroundColor>ffffffff</backgroundColor>
            <backgroundRelativeScale>1.0</backgroundRelativeScale>
            <backgroundCornerRadius>${radTile}</backgroundCornerRadius>
            <selectorImage>./../assets/ui/selector-frame.svg</selectorImage>
            <selectorRelativeScale>1.0</selectorRelativeScale>
            <selectorLayer>top</selectorLayer>
            <unfocusedItemOpacity>1.0</unfocusedItemOpacity>
            <unfocusedItemDimming>0.76</unfocusedItemDimming>
            <unfocusedItemSaturation>0.7</unfocusedItemSaturation>
            <zIndex>30</zIndex>
        </grid>
    </view>

    <!-- DESKTOP (side-panel layout): top-left header + right detail panel -->
    <aspectRatio name="16:9, 16:10, 4:3, 5:4">
        <view name="gamelist">
            <!-- header sits below the section-strip top bar (which ends at y 0.056) -->
            <text name="glHeader">
                <pos>0.035 0.064</pos><size>0.6 0.05</size>
                <text>${systemName}</text>
                <fontPath>${fontDisplay}</fontPath><fontSize>${fsHeader}</fontSize>
                <color>${cText}</color><zIndex>20</zIndex>
            </text>
            <gamelistinfo name="glCount">
                <pos>0.035 ${glCountY}</pos><size>0.3 0.03</size>
                <fontPath>${fontSemiBold}</fontPath><fontSize>${fsTab}</fontSize>
                <color>${cText2}</color><zIndex>20</zIndex>
            </gamelistinfo>
        </view>
        <include>./detail.xml</include>
    </aspectRatio>

    <!-- PHONE / ULTRAWIDE (hero-banner layout): full-width top banner, no detail panel -->
    <aspectRatio name="19.5:9, 20:9, 21:9">
        <include>./gamelist_banner.xml</include>
    </aspectRatio>
</theme>
