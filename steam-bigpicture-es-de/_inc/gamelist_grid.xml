<theme>
    <include>./helpsystem.xml</include>
    <include>./status.xml</include>
    <include>./detail.xml</include>
    <view name="gamelist">
        <!-- Steam library backdrop (dark blue-grey, not black) behind the whole view -->
        <image name="gridBg">
            <pos>0 0</pos><size>1 1</size>
            <path>./../assets/ui/grid-bg.svg</path>
            <zIndex>1</zIndex>
        </image>
        <!-- header sits below the section-strip top bar (which ends at y 0.056) -->
        <text name="glHeader">
            <pos>0.035 0.064</pos><size>0.6 0.05</size>
            <!-- use ${systemName} (matches the system-view name + honours the collection renames) -->
            <text>${systemName}</text>
            <fontPath>${fontDisplay}</fontPath><fontSize>${fsHeader}</fontSize>
            <color>${cText}</color><zIndex>20</zIndex>
        </text>
        <gamelistinfo name="glCount">
            <pos>0.035 0.108</pos><size>0.3 0.03</size>
            <fontPath>${fontSemiBold}</fontPath><fontSize>${fsTab}</fontSize>
            <color>${cText2}</color><zIndex>20</zIndex>
        </gamelistinfo>
        <grid name="capsules">
            <pos>0.035 0.16</pos><size>0.64 0.74</size>
            <imageType>cover</imageType>
            <!-- no defaultImage: in a gamelist grid the game name is the automatic fallback
                 when no cover is found, so art-less tiles show the title (styled below) -->
            <textColor>${cText}</textColor>
            <textBackgroundColor>00000000</textBackgroundColor>
            <textRelativeScale>0.86</textRelativeScale>
            <fontPath>${fontSemiBold}</fontPath>
            <fontSize>${fsTab}</fontSize>
            <!-- compact grid: smaller cells + tight spacing pack more capsules per screen -->
            <itemSize>${gridItemX} ${gridItemY}</itemSize>
            <itemSpacing>${gridSpacing}</itemSpacing>
            <!-- Steam focus: subtle scale + a thin frame at the capsule edge; scaleInwards keeps edge rows in bounds -->
            <itemScale>1.04</itemScale>
            <scaleInwards>true</scaleInwards>
            <!-- show partial rows top/bottom so there's visible scroll context (mitigates the
                 "stuck on the last row" feel; ES-DE has no selection-anchor property) -->
            <fractionalRows>true</fractionalRows>
            <!-- full-bleed capsules: cover fills the cell so there is no dark margin "ring" and no
                 uneven L/R vs T/B margin (a uniform inset on a portrait cell gives unequal px
                 margins). The gap between tiles comes from itemSpacing. A per-tile drop shadow
                 can't extend beyond the cell in ES-DE, so the in-margin fake read as a hard box
                 on phones - dropped here in favour of clean full-bleed. -->
            <imageFit>cover</imageFit>
            <imageRelativeScale>1.0</imageRelativeScale>
            <imageCornerRadius>${radTile}</imageCornerRadius>
            <!-- card base for un-scraped (text-fallback) tiles -->
            <backgroundColor>1a222dff</backgroundColor>
            <backgroundCornerRadius>${radTile}</backgroundCornerRadius>
            <!-- thin light-grey focus frame at the cell edge (hugs the full-bleed capsule) -->
            <selectorImage>./../assets/ui/selector-frame.svg</selectorImage>
            <selectorLayer>top</selectorLayer>
            <!-- Steam shows neighbours at full brightness; only a hair of dim for couch focus aid -->
            <unfocusedItemOpacity>0.92</unfocusedItemOpacity>
            <zIndex>30</zIndex>
        </grid>
    </view>
</theme>
