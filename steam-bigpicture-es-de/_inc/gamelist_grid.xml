<theme>
    <include>./helpsystem.xml</include>
    <include>./status.xml</include>
    <include>./detail.xml</include>
    <view name="gamelist">
        <text name="glHeader">
            <pos>0.035 0.05</pos><size>0.6 0.06</size>
            <metadata>systemFullname</metadata>
            <fontPath>${fontExtraBold}</fontPath><fontSize>0.036</fontSize>
            <color>${cText}</color><zIndex>20</zIndex>
        </text>
        <gamelistinfo name="glCount">
            <pos>0.035 0.11</pos><size>0.3 0.03</size>
            <fontPath>${fontSemiBold}</fontPath><fontSize>0.02</fontSize>
            <color>${cText2}</color><zIndex>20</zIndex>
        </gamelistinfo>
        <grid name="capsules">
            <pos>0.035 0.16</pos><size>0.64 0.74</size>
            <imageType>cover</imageType>
            <!-- no defaultImage: in a gamelist grid the game name is the automatic fallback
                 when no cover is found, so art-less tiles show the title (styled below) -->
            <textColor>${cText}</textColor>
            <textBackgroundColor>00000000</textBackgroundColor>
            <fontPath>${fontSemiBold}</fontPath>
            <fontSize>0.018</fontSize>
            <itemSize>0.10 0.205</itemSize>
            <itemSpacing>0.016 0.024</itemSpacing>
            <itemScale>1.06</itemScale>
            <scaleInwards>true</scaleInwards>
            <!-- contain = whole cover always shown (never crops/cuts box art like 'cover' does);
                 the rounded plate fills the tile so framed covers still look intentional -->
            <imageFit>contain</imageFit>
            <!-- consistent inset so the rounded accent selector reads as a uniform frame -->
            <imageRelativeScale>0.92</imageRelativeScale>
            <imageCornerRadius>${rad}</imageCornerRadius>
            <backgroundColor>1a1f27ff</backgroundColor>
            <backgroundCornerRadius>${rad}</backgroundCornerRadius>
            <selectorColor>${cAccent}</selectorColor>
            <selectorCornerRadius>${rad}</selectorCornerRadius>
            <selectorLayer>middle</selectorLayer>
            <unfocusedItemOpacity>0.55</unfocusedItemOpacity>
            <zIndex>30</zIndex>
        </grid>
    </view>
</theme>
