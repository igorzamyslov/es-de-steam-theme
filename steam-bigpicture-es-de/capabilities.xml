<!-- Steam Big Picture for ES-DE -->
<themeCapabilities>
    <themeName>Steam Big Picture</themeName>

    <aspectRatio>16:9</aspectRatio>
    <aspectRatio>16:10</aspectRatio>
    <aspectRatio>4:3</aspectRatio>
    <aspectRatio>5:4</aspectRatio>
    <aspectRatio>19.5:9</aspectRatio>
    <aspectRatio>20:9</aspectRatio>
    <aspectRatio>21:9</aspectRatio>

    <fontSize>medium</fontSize>
    <fontSize>large</fontSize>
    <fontSize>x-large</fontSize>

    <colorScheme name="dark">
        <label language="en_US">Dark</label>
    </colorScheme>

    <transitions name="steam">
        <label language="en_US">Steam</label>
        <selectable>true</selectable>
        <systemToSystem>instant</systemToSystem>
        <systemToGamelist>slide</systemToGamelist>
        <gamelistToGamelist>instant</gamelistToGamelist>
        <gamelistToSystem>slide</gamelistToSystem>
        <startupToSystem>fade</startupToSystem>
        <startupToGamelist>fade</startupToGamelist>
    </transitions>

    <!-- 2 system heroes x 2 gamelist layouts x 2 detail media = 8 variants.
         First entry is the default: Hero (neon) · Grid · Marquee. -->
    <variant name="heroNeonGridMarquee"><label language="en_US">Hero (neon) · Grid · Marquee</label><selectable>true</selectable></variant>
    <variant name="heroNeonGridShot"><label language="en_US">Hero (neon) · Grid · Screenshot</label><selectable>true</selectable></variant>
    <variant name="heroNeonListMarquee"><label language="en_US">Hero (neon) · List · Marquee</label><selectable>true</selectable></variant>
    <variant name="heroNeonListShot"><label language="en_US">Hero (neon) · List · Screenshot</label><selectable>true</selectable></variant>
    <variant name="heroArtGridMarquee"><label language="en_US">Hero (art) · Grid · Marquee</label><selectable>true</selectable></variant>
    <variant name="heroArtGridShot"><label language="en_US">Hero (art) · Grid · Screenshot</label><selectable>true</selectable></variant>
    <variant name="heroArtListMarquee"><label language="en_US">Hero (art) · List · Marquee</label><selectable>true</selectable></variant>
    <variant name="heroArtListShot"><label language="en_US">Hero (art) · List · Screenshot</label><selectable>true</selectable></variant>
</themeCapabilities>
