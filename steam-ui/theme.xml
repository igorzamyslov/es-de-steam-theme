<!-- system icons: ./system-controllers-outline/${system.theme}.svg ; logos: ./system-logos/system-logo-white/${system.theme}.svg (color: ./system-logos/system-logo-color/${system.theme}.svg) ; metadata: ./system-metadata/${system.theme}.xml -->
<theme>
    <include>./_inc/fonts.xml</include>
    <include>./_inc/colors.xml</include>
    <!-- size/scale variables (font-size + aspect-ratio); must precede the variant includes -->
    <include>./_inc/scale.xml</include>

    <!-- detail-panel media (detailMediaType + mediaDelay) is set by the selected colorScheme below,
         matching the official-theme pattern (scheme-controlled vars live only in colorScheme blocks,
         never at root, so nothing competes with the selection). -->
    <variables>
        <!-- corner-radius tokens. Big Picture is fully rectangular, so these are 0.
             Kept as tokens (not removed) so fillets can be re-enabled in one place;
             cornerRadius is screen-WIDTH-relative in ES-DE (same px on every element). -->
        <rad>0</rad>          <!-- detail media -->
        <radTile>0</radTile>      <!-- grid capsules -->
        <radButton>0</radButton>  <!-- short controls e.g. Play -->
        <!-- NOTE: section-strip nav defaults live in _inc/section-state/_default.xml, NOT here:
             root-level variables take precedence over included ones in ES-DE, so defaults kept
             here could never be overridden by the per-collection section-state includes. -->
    </variables>

    <!-- Detail-panel media behaviour lives on the colorScheme axis (one shared dark palette).
         detailMediaType = the still shown first; mediaDelay = seconds before the video plays
         (100000 = effectively "no video": the still just stays). Must be a colorScheme (not a
         variant) so it is independent of the hero/layout variant; variants are resolved later and
         would otherwise override these. The detail media is cover-cropped to a fixed box, so the
         chain is screenshot-first (marquee schemes were removed — wide logos crop badly). -->
    <colorScheme name="screenshotVideo"><variables><detailMediaType>screenshot, cover</detailMediaType><mediaDelay>2.5</mediaDelay></variables></colorScheme>
    <colorScheme name="screenshotStill"><variables><detailMediaType>screenshot, cover</detailMediaType><mediaDelay>100000</mediaDelay></variables></colorScheme>

    <!-- 4 variants = {hero neon, hero art} x {grid, list}. Detail media is the colorScheme axis above.
         First variant is the default: Hero (neon) · Grid. -->
    <variant name="heroNeonGrid">
        <include>./_inc/system_hero_neon.xml</include>
        <include>./_inc/gamelist_grid.xml</include>
    </variant>
    <variant name="heroNeonList">
        <include>./_inc/system_hero_neon.xml</include>
        <include>./_inc/gamelist_list.xml</include>
    </variant>
    <variant name="heroArtGrid">
        <include>./_inc/system_hero_art.xml</include>
        <include>./_inc/gamelist_grid.xml</include>
    </variant>
    <variant name="heroArtList">
        <include>./_inc/system_hero_art.xml</include>
        <include>./_inc/gamelist_list.xml</include>
    </variant>

    <!-- Aspect-ratio reflow overrides are deferred (must be variant-scoped; a global
         override leaks a second primary element). Base layout uses normalized coords. -->
</theme>
