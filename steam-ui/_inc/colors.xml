<theme>
    <!-- Shared palette. Kept as global variables (not inside a colorScheme block) because the
         colorScheme axis is repurposed to pick the detail-panel media behaviour, not colours -
         every scheme shares this one dark palette. cAccent (a bright Steam blue) is the accent for
         the three collection tabs (Library/Favorites/Recent). The Platforms underline tracks the
         per-system ${systemColor} (which also drives the hero tint); very dark systems are lifted
         in section-accent/. The rail icons use fixed colours (unselected = neutral grey,
         selected = white) - carousel tints can't safely take a per-system variable. Background/
         panel/green colours are baked into the SVG assets in assets/ui/. -->
    <variables>
        <cAccent>33a8ffff</cAccent>
        <cText>e8edf2ff</cText>
        <cText2>aab4c0ff</cText2>
        <cMuted>8a94a0ff</cMuted>
        <cStar>f5c518ff</cStar>
    </variables>
</theme>
