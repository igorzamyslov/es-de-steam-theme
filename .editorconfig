root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.xml]
indent_style = space
indent_size = 4

[*.svg]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,jsonc}]
indent_style = space
indent_size = 2

# Markdown: keep trailing whitespace (two spaces = hard line break)
[*.md]
trim_trailing_whitespace = false

# Vendored upstream assets — leave exactly as imported
[steam-ui/{system-logos,system-controllers-outline,system-metadata}/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
